#
# For a description of the syntax of this configuration file,
# see kconfig-language at https://www.kernel.org/doc/Documentation/kbuild/kconfig-language.txt
#

comment "Basic CXX Support"

config C99_BOOL8
	bool "sizeof(_Bool) is 8-bits"
	default n
	---help---
		This setting means (1) your C++ compiler has sizeof(_Bool) == 8, (2)
		your C compiler supports the C99 _Bool intrinsic type, and (2) that
		the C99 _Bool type also has size 1.

config HAVE_CXX
	bool "Have C++ compiler"
	default n
	---help---
		Toolchain supports C++ and CXX, CXXFLAGS, and COMPILEXX have been
		defined in the configurations Make.defs file.

if HAVE_CXX

choice CXX_VERSION
	prompt "c++version"
	default CXX_VERSION_11

config CXX_VERSION_11
	bool "c++11"

config CXX_VERSION_14
	bool "c++14"

config CXX_VERSION_17
	bool "c++17"

endchoice

config CXX_NEWLONG
	bool "size_t is type long"
	default n
	---help---
		size_t may be type long or type int.  This matters for some
		C++ library routines because the TinyAra size_t might not have
		the same underlying type as your toolchain's size_t.


comment "LLVM C++ Library (libcxx)"

config LIBCXX
	bool "Build LLVM libcxx"
	default n
	select HAVE_CXXINITIALIZE if BUILD_FLAT
	select BINFMT_CONSTRUCTORS if APP_BINARY_SEPARATION
	---help---
		LLVM libc++ can be built by selecting this option.

if LIBCXX

config LIBCXX_EXCEPTION
	bool "Enable Exception Suppport"
	default y
	---help---
		Enable exception support in libc++.

		NOTE:  Enabling can cause crashes due to cross-compiler 'arm-none-eabi-g++' version (10.3.1).
		If you are enabling C++ exception then use docker image version 2.0.0. Use
		menuconfig (Build Setup -> Docker Image Version) to set CONFIG_DOCKER_VERSION=2.0.0

config LIBCXX_FILESYSTEM
    bool "Enable full filesystem support"
    default n
    ---help---
        Enable std::filesystem directory operations, iterators, and file status
        functions. This requires sys/statvfs.h and related system calls, which are not currently available.
        Without statvfs.h, enabling this flag will result in build errors.

        When disabled, basic path manipulation support is still available
        (path, filesystem_error, filesystem_clock).

config LIBCXX_TIME_UTC
    bool "Enable C++17 UTC time support"
    default n
    ---help---
        Enable std::timespec and std::timespec_get support (C++17).
        Requires TizenRT C library to provide timespec_get() and TIME_UTC.
        Currently TizenRT does not provide these, so this must remain disabled
        until they are implemented in the C library.

config LIBCXX_IOSTREAM_BUFSIZE
	int "IO Stream Buffer Size"
	default 32

config LIBCXX_HAVE_LIBSUPCXX
	bool "Have libsupc++ (required)"
	default y
	---help---
		Select if your toolchain provides libsupc++.  This option is required
		at present because the built-in libsupc++ support is incomplete.


choice LIBCXX_PSTL_BACKEND
	prompt "Parallel STL CPU Backend"
	default LIBCXX_PSTL_BACKEND_SERIAL
	---help---
		Select the Parallel STL (PSTL) CPU backend for C++17 parallel algorithms.
		SERIAL is recommended for embedded systems.

config LIBCXX_PSTL_BACKEND_SERIAL
	bool "Serial (No Parallelism)"
	---help---
		Execute all parallel algorithms sequentially.		
		Recommended for embedded systems:
		- No threading overhead
		- Minimal code size
		- No pthread dependency for parallel algorithms
		- Deterministic execution		
		Use this when: No multi-threading support or constrained resources.

config LIBCXX_PSTL_BACKEND_THREAD
	bool "Thread (std::thread based)"
	---help---
		Use std::thread for actual parallel execution.		
		Requires:
		- Full pthread implementation
		- Thread pool infrastructure
		- Sufficient memory for thread stacks		
		Use this when: Multi-core CPU with full threading support.

config LIBCXX_PSTL_BACKEND_LIBDISPATCH
	bool "libdispatch (Apple's Grand Central Dispatch)"
	---help---
		Use Apple's Grand Central Dispatch for parallel execution.		
		NOTE: Not available on TizenRT - requires Apple's libdispatch library.

endchoice

endif

endif
