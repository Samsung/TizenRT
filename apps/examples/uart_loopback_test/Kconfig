#
# For a description of the syntax of this configuration file,
# see kconfig-language at https://www.kernel.org/doc/Documentation/kbuild/kconfig-language.txt
#

config UART_LOOPBACK_TEST
	bool "UART loopback test application"
	default n
	---help---
		Enable UART loopback test application

if UART_LOOPBACK_TEST

config UART_LOOPBACK_PORT
	int "UART loopback tty port "
	default 2
	---help---
		The CONFIG_UART_LOOPBACK_PORT sets test UART ttyS* port
		The default port is ttyS2

endif #UART_LOOPBACK_TEST
