#
# For a description of the syntax of this configuration file,
# see kconfig-language at https://www.kernel.org/doc/Documentation/kbuild/kconfig-language.txt
#

comment "QEMU Virt Chipset Options"

if ARCH_CHIP_QEMU_ARM_VIRT

menu "Qemu Virt Configuration"

config QEMU_VIRT_PROFILE_RTL8730E
	bool "RTL8730E execution profile"
	default y
	---help---
		Select the qemu-virt execution profile intended to model the
		rtl8730e software environment on an A-profile QEMU virt machine.

config QEMU_VIRT_CPU_MODEL
	string "QEMU virt CPU model"
	default "cortex-a15" if QEMU_VIRT_PROFILE_RTL8730E
	default "cortex-a15"
	---help---
		CPU model passed to QEMU for the qemu-virt runtime.

config QEMU_VIRT_MEMORY_MB
	int "QEMU virt memory size (MiB)"
	range 32 4096
	default 64 if QEMU_VIRT_PROFILE_RTL8730E
	default 64
	---help---
		Guest memory size passed to QEMU for the qemu-virt runtime.

config QEMU_VIRT_SMP_DEFAULT
	int "Default CPU count for qemu-virt SMP"
	range 1 4
	default 2 if QEMU_VIRT_PROFILE_RTL8730E
	default 1
	---help---
		Fallback CPU count used by qemu-virt runtime helpers when SMP is
		enabled but CONFIG_SMP_NCPUS is not explicitly set in a defconfig.

config QEMU_VIRT_ARCH_TIMER_FREQ
	int "Architected timer frequency"
	default 62500000 if QEMU_VIRT_PROFILE_RTL8730E
	default 62500000
	---help---
		Architected timer frequency used by the qemu-virt timer driver.

config QEMU_VIRT_MOUNT_FLASH_PARTITIONS
	bool "Mount flash partitions during board init"
	default y if QEMU_VIRT_PROFILE_RTL8730E
	default y
	---help---
		Initialize the in-tree CFI-backed flash layout and mount the runtime
		filesystems during board initialization.

config QEMU_VIRT_INIT_FTL
	bool "Initialize FTL during board init"
	depends on FTL_ENABLED
	default y if QEMU_VIRT_PROFILE_RTL8730E
	default y if FTL_ENABLED
	---help---
		Run the generic FTL initialization step during board initialization.

config QEMU_VIRT_INIT_VIRTIO_BLK_AT_BOOT
	bool "Initialize virtio-blk during board init"
	depends on QEMU_VIRT_VIRTIO_BLK
	default y if QEMU_VIRT_PROFILE_RTL8730E
	default y if QEMU_VIRT_VIRTIO_BLK
	---help---
		Bring up the virtio-blk transport during board initialization so the
		runtime environment matches the rtl8730e execution profile assumptions.

if BOOT_RUNFROMSDRAM
config QEMU_KERNEL_LOAD_ADDR
	hex "Kernel Load address"
	default 0x40100000
endif #BOOT_RUNFROMSDRAM

choice
	prompt "Qemu Core Configuration"
	default ARCH_CHIP_QEMU_CORTEXA15

config ARCH_CHIP_QEMU_CORTEXA15
	bool "Qemu virtual Processor (cortex-a15)"
	select ARCH_CORTEXA15
	select ARCH_HAVE_ADDRENV
	select ARCH_HAVE_ELF_EXECUTABLE
	select ARCH_HAVE_LOWVECTORS
	select ARCH_HAVE_MULTICPU
	select ARCH_NEED_ADDRENV_MAPPING
	select ARM_HAVE_NEON
	select ARM_HAVE_PSCI
	select ARMV7A_HAVE_GICv2
	select ARCH_HAVE_FPU
	select ARMV7A_HAVE_GTM
	select ARMV7A_HAVE_PTM
	select ARCH_BOARD_HAVE_SECOND_FLASH

endchoice

config ARCH_CHIP_QEMU_TRUSTZONE
	bool "Enable Arm Security Extensions (TrustZone)"
	select ARCH_HAVE_TRUSTZONE
	default n
	---help---
		Doc: https://qemu-project.gitlab.io/qemu/system/arm/virt.html
		shows that set secure=on/of can emulating a guest CPU which
		implements the Arm Security Extensions (TrustZone).
		The default is off. And this config can enable/disable
		TrustZone in qemu chip.
		(Currently not supported.)

config ARM_HAVE_PSCI
	bool "ARM PSCI (Power State Coordination Interface) Support"
	default n
	---help---
		This Power State Coordination Interface (PSCI) defines
		a standard interface for power management. the PCSI need
		to implement handling firmware at EL2 or EL3. The option
		maybe not applicable for arm core without PCSI firmware
		interface implement

config ARM_PSCI
	bool "Enabled PSCI"
	depends on ARM_HAVE_PSCI
	default y if QEMU_VIRT_PROFILE_RTL8730E
	default n
	---help---
		See ARM_HAVE_PSCI for details


menuconfig UART_PL011
	bool "PL011 Chip support"
	default y if QEMU_VIRT_PROFILE_RTL8730E
	default n

if UART_PL011
source "arch/arm/src/qemu-virt/Kconfig-pl011"
endif

# Virtio support
source "arch/arm/src/qemu-virt/virtio/Kconfig"

endmenu # "Qemu Virt Configuration"

endif # ARCH_CHIP_QEMU_ARM_VIRT
