#
# For a description of the syntax of this configuration file,
# see kconfig-language at https://www.kernel.org/doc/Documentation/kbuild/kconfig-language.txt
#

config LIBCXX_UTC
	bool "Unit Test for LLVM Libc++"
	default n
	depends on LIBCXX
	depends on HAVE_CXXINITIALIZE || BINFMT_CONSTRUCTORS
	---help---
		Enables unit test for LLVM Libc++.

config LIBCXX_UTC_ALGORITHMS
	bool "UTC for Libc++ Algorithms"
	default y
	depends on LIBCXX_UTC
	---help---
		UTC for Libc++ Algorithms

config LIBCXX_UTC_ALGORITHMS_NONMOD
	bool "UTC for Libc++ Non-modifying Algorithms"
	default y
	depends on LIBCXX_UTC_ALGORITHMS
	---help---
		UTC for Libc++ Non-modifying Algorithms (find, count, search, equal, etc.)

config LIBCXX_UTC_ALGORITHMS_MOD
	bool "UTC for Libc++ Modifying Algorithms"
	default y
	depends on LIBCXX_UTC_ALGORITHMS
	---help---
		UTC for Libc++ Modifying Algorithms (copy, move, swap, transform, fill, etc.)

config LIBCXX_UTC_ALGORITHMS_SORT
	bool "UTC for Libc++ Sorting Algorithms"
	default y
	depends on LIBCXX_UTC_ALGORITHMS
	---help---
		UTC for Libc++ Sorting Algorithms (sort, merge, heap, min/max, etc.)

config LIBCXX_UTC_ALGORITHMS_CLIB
	bool "UTC for Libc++ C Library Algorithms"
	default y
	depends on LIBCXX_UTC_ALGORITHMS
	---help---
		UTC for Libc++ C Library Algorithms (bsearch, qsort)

config LIBCXX_UTC_ALGORITHMS_NUMERIC
	bool "UTC for Libc++ Numeric Algorithms"
	default y
	depends on LIBCXX_UTC_ALGORITHMS
	---help---
		UTC for Libc++ Numeric Algorithms (accumulate, reduce, gcd, lcm, etc.)

