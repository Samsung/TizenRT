#ifndef _LIBCPP_CONFIG_SITE
#define _LIBCPP_CONFIG_SITE

// TizenRT specific configurations for __TINYARA__ platform
#define _LIBCPP_ABI_VERSION 2
#define _LIBCPP_HAS_THREAD_API_PTHREAD

// Embedded system constraints for TizenRT
#define _LIBCPP_HAS_NO_FILESYSTEM
#define _LIBCPP_HAS_NO_WIDE_CHARACTERS
#define _LIBCPP_HAS_NO_RANDOM_DEVICE
#define _LIBCPP_HAS_NO_SYSTEM_ERROR
#define _LIBCPP_HAS_NO_UNICODE
#define _LIBCPP_HAS_NO_THREAD_UNSAFE_C_FUNCTIONS
#define _LIBCPP_HAS_NO_GLOBAL_FILESYSTEM_NAMESPACE
#define _LIBCPP_HAS_NO_STDIN
#define _LIBCPP_HAS_NO_STDOUT

// Additional constraints for older compiler compatibility
#define _LIBCPP_HAS_NO_FGETPOS_FSETPOS

// Compiler built-in function fallbacks for arm-none-eabi-g++
// These are required for libc++ 17.0.6 compatibility
// For embedded systems, assume nothrow for simple types to avoid compilation issues
#ifndef __is_nothrow_assignable
#define __is_nothrow_assignable(T, U) true
#endif

#ifndef __is_nothrow_constructible
#define __is_nothrow_constructible(...) true
#endif

#ifndef __is_nothrow_move_assignable
#define __is_nothrow_move_assignable(T) true
#endif

#ifndef __is_nothrow_move_constructible
#define __is_nothrow_move_constructible(T) true
#endif

#ifndef __is_nothrow_copy_assignable
#define __is_nothrow_copy_assignable(T) true
#endif

#ifndef __is_nothrow_default_constructible
#define __is_nothrow_default_constructible(T) true
#endif

// mbstate_t definition for embedded systems when wide characters are disabled
#if defined(_LIBCPP_HAS_NO_WIDE_CHARACTERS)
struct mbstate_t {
    int __fill[6];
};
#endif

// C++17 feature compatibility fixes for TizenRT
#define _LIBCPP_HAS_NO_TIME_UTC
#define _LIBCPP_HAS_NO_RANGES

// Parallel STL (PSTL) backend configuration for embedded systems
#define _LIBCPP_PSTL_CPU_BACKEND_SERIAL

// __bit_log2 fallback for C++17 compatibility
#define _LIBCPP_BIT_LOG2_FALLBACK

// Debug and assertion configuration
#define _LIBCPP_ENABLE_ASSERTIONS_DEFAULT 0
#define _LIBCPP_ENABLE_HARDENED_MODE_DEFAULT 0
#define _LIBCPP_ENABLE_DEBUG_MODE_DEFAULT 0

// Optional features for embedded systems (disable if not needed)
#define _LIBCPP_NO_EXCEPTIONS
#define _LIBCPP_NO_RTTI


// TizenRT compatibility: Disable debug mode for embedded systems
#define _LIBCPP_HAS_NO_DEBUG_MODE 1

// TizenRT compatibility: Disable nullptr_t constructor for void* to avoid overload conflict
#define _LIBCPP_HAS_NULLPTR_T_FOR_VOID 0

// TizenRT compatibility: Define _LIBCPP_SAFE_STATIC for thread-safe static initialization
#define _LIBCPP_SAFE_STATIC _LIBCPP_CONSTEXPR

// TizenRT compatibility: Disable aligned_alloc as TizenRT C library doesn't provide it
#define _LIBCPP_HAS_NO_C11_ALIGNED_ALLOC

// TizenRT compatibility: Disable library aligned allocation as TizenRT C library doesn't provide posix_memalign
#define _LIBCPP_HAS_NO_LIBRARY_ALIGNED_ALLOCATION

// TizenRT compatibility: Provide locale mask fallback definitions
// These are needed for locale support but not provided by TizenRT's C library
#ifndef LC_COLLATE_MASK
#define LC_COLLATE_MASK (1<<0)
#endif
#ifndef LC_CTYPE_MASK
#define LC_CTYPE_MASK (1<<1)
#endif
#ifndef LC_MONETARY_MASK
#define LC_MONETARY_MASK (1<<2)
#endif
#ifndef LC_NUMERIC_MASK
#define LC_NUMERIC_MASK (1<<3)
#endif
#ifndef LC_TIME_MASK
#define LC_TIME_MASK (1<<4)
#endif
#ifndef LC_MESSAGES_MASK
#define LC_MESSAGES_MASK (1<<5)
#endif

// Define LC_ALL_MASK as the combination of all locale masks
#ifndef LC_ALL_MASK
#define LC_ALL_MASK (LC_COLLATE_MASK | LC_CTYPE_MASK | LC_MONETARY_MASK | LC_NUMERIC_MASK | LC_TIME_MASK | LC_MESSAGES_MASK)
#endif

// Define wint_t for systems that don't provide it properly
typedef unsigned int wint_t;

// TizenRT needs stdio file functions for iostream
#define _LIBCPP_NEEDS_STDIO_FILE_FUNCTIONS

#endif // _LIBCPP_CONFIG_SITE
