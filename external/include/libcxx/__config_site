#ifndef _LIBCPP_CONFIG_SITE
#define _LIBCPP_CONFIG_SITE

// TizenRT specific configurations for __TINYARA__ platform
#define _LIBCPP_ABI_VERSION 2

//use the standard pthread functions for thread management, synchronization, and condition variables
#define _LIBCPP_HAS_THREAD_API_PTHREAD

// Embedded system constraints for TizenRT
// TizenRT compatibility: C library doesn't fully implement wide character functions
// making wide character and Unicode support impractical
// Disable wide characters (not fully supported)
#define _LIBCPP_HAS_NO_WIDE_CHARACTERS
#define _LIBCPP_HAS_NO_UNICODE

//ensure that only reentrant/thread-safe versions of functions are available
#define _LIBCPP_HAS_NO_THREAD_UNSAFE_C_FUNCTIONS

//TizenRT's C library provides only partial stdio implementation
// some functions are missing, others are macros only.
#define _LIBCPP_HAS_NO_STDIN
#define _LIBCPP_HAS_NO_STDOUT
// TizenRT needs stdio file only provides macro of `getc` and `putc` 
// ensure `getc` and `putc` maps to `fgetc`/`fputc` 
#define _LIBCPP_NEEDS_STDIO_FILE_FUNCTIONS

// arm-none-eabi-g++ 10.x has missing/incomplete C++ standard library features
// This will auto-detect and enable workarounds. Remove these workarounds when 
// the compiler is upgraded to a version with full C++ support.
#if defined(__arm__) && defined(__GNUC__) && __GNUC__ == 10
#define LIBCPP_ARM_EABI_GCC10_WORKAROUND 1
#endif

// 'arm-none-eabi-g++' (10.3.1) cross-compiler does not provide the Clang-specific
// compiler built-in intrinsics `__is_nothrow_assignable` and `__is_nothrow_constructible`
// Following macros are defined to return `true` for all types (assume nothrow),
// to avoid compilation issues
#ifndef __is_nothrow_assignable
#define __is_nothrow_assignable(T, U) true
#endif

#ifndef __is_nothrow_constructible
#define __is_nothrow_constructible(...) true
#endif

#ifndef __is_nothrow_move_assignable
#define __is_nothrow_move_assignable(T) true
#endif

#ifndef __is_nothrow_move_constructible
#define __is_nothrow_move_constructible(T) true
#endif

#ifndef __is_nothrow_copy_assignable
#define __is_nothrow_copy_assignable(T) true
#endif

#ifndef __is_nothrow_default_constructible
#define __is_nothrow_default_constructible(T) true
#endif

// C++20 feature detection for concepts and requires expressions
#if defined(LIBCPP_ARM_EABI_GCC10_WORKAROUND) || (defined(_LIBCPP_COMPILER_GCC) && defined(__GNUC__) && __GNUC__ <= 10) || defined(_LIBCPP_HAS_NO_CXX20_FEATURES)
#  define _LIBCPP_HAS_NO_CONCEPTS
#  define _LIBCPP_HAS_NO_REQUIRES_EXPR
#elif defined(__cpp_concepts) && __cpp_concepts >= 201907L
#  define _LIBCPP_HAS_CONCEPTS
#  define _LIBCPP_HAS_REQUIRES_EXPR
#else
#  define _LIBCPP_HAS_NO_CONCEPTS
#  define _LIBCPP_HAS_NO_REQUIRES_EXPR
#endif

#if defined(_LIBCPP_HAS_NO_WIDE_CHARACTERS)
// Google Test/Mock compatibility: Disable wide string functionality
#define _LIBCPP_HAS_NO_GTEST_WIDE_STRINGS

// TizenRT compatibility: Define mbstate_t and wint_t when not provided by platform.
// TizenRT already provides these in os/include/wchar.h, so skip for __TINYARA__.
#if !defined(__TINYARA__)

#ifndef mbstate_t
struct mbstate_s { int __fill[6]; };
typedef struct mbstate_s mbstate_t;
#endif  //mbstate_t

#ifndef wint_t
// Define wint_t for systems that don't provide it properly
typedef unsigned int wint_t;
#endif  //wint_t
#endif  //__TINYARA__
#endif  //_LIBCPP_HAS_NO_WIDE_CHARACTERS

// C++17 feature compatibility fixes for TizenRT

// UTC time support configuration (set via Kconfig)
// Disabled by default for TizenRT (no timespec_get / TIME_UTC in C library)
#ifndef CONFIG_LIBCXX_TIME_UTC
#define _LIBCPP_HAS_NO_TIME_UTC
#endif

// Platform property: TizenRT does not have a global filesystem namespace
//(e.g., no root `/`, no `statvfs`, etc.)
#define _LIBCPP_HAS_NO_GLOBAL_FILESYSTEM_NAMESPACE

// Filesystem support configuration (set via Kconfig)
// Disabled by default for TizenRT (no sys/statvfs.h)
#ifndef CONFIG_LIBCXX_FILESYSTEM
#define _LIBCPP_HAS_NO_FILESYSTEM
#endif

// Parallel STL (PSTL) Backend configuration (set via Kconfig)
// Default to SERIAL if no backend is explicitly selected
#if defined(CONFIG_LIBCXX_PSTL_BACKEND_THREAD)
#define _LIBCPP_PSTL_CPU_BACKEND_THREAD
#elif defined(CONFIG_LIBCXX_PSTL_BACKEND_LIBDISPATCH)
#define _LIBCPP_PSTL_CPU_BACKEND_LIBDISPATCH
#else
// Default: serial backend (CONFIG_LIBCXX_PSTL_BACKEND_SERIAL or no selection)
#define _LIBCPP_PSTL_CPU_BACKEND_SERIAL
#endif

// <= C++17-: in bit_log2.h, __bit_log2 is undefined without this fallback, breaking algorithm.cpp (introsort)
// >= C++20: __bit_log2 uses countl_zero (__builtin_clz), making this fallback unnecessary
#if __cplusplus < 202002L
#define _LIBCPP_BIT_LOG2_FALLBACK
#endif

// Debug and assertion configuration
// TizenRT hardening mode via Kconfig (mutually exclusive options)
// See: https://libcxx.llvm.org/Hardening.html
#if defined(CONFIG_LIBCXX_HARDENING_ASSERTIONS)
#define _LIBCPP_ENABLE_ASSERTIONS_DEFAULT 1
#else
#define _LIBCPP_ENABLE_ASSERTIONS_DEFAULT 0
#endif

#if defined(CONFIG_LIBCXX_HARDENING_HARDENED)
#define _LIBCPP_ENABLE_HARDENED_MODE_DEFAULT 1
#else
#define _LIBCPP_ENABLE_HARDENED_MODE_DEFAULT 0
#endif

#if defined(CONFIG_LIBCXX_HARDENING_DEBUG)
#define _LIBCPP_ENABLE_DEBUG_MODE_DEFAULT 1
#else
#define _LIBCPP_ENABLE_DEBUG_MODE_DEFAULT 0
#endif

// TizenRT custom verbose abort - integrates with TizenRT's assertion system
// Use __builtin_abort() which is always available and has no header dependencies.
#if !defined(CONFIG_LIBCXX_HARDENING_DISABLED) && defined(CONFIG_LIBCXX_HARDENING_VERBOSE)
#define _LIBCPP_VERBOSE_ABORT(format, ...) \
    ({ \
        __builtin_abort(); \
    })
#endif

// Controls whether libcxx RTTI features are available (compiler's -frtti/-fno-rtti flags )
#if defined(CONFIG_LIBCXX_RTTI_FORCE_ON)
    // Explicitly forced on — user must ensure -frtti in board config
    // Do NOT define _LIBCPP_NO_RTTI
#elif defined(CONFIG_LIBCXX_RTTI_FORCE_OFF)
    // Explicitly forced off — disable RTTI unconditionally
    #define _LIBCPP_NO_RTTI
#else
    // CONFIG_LIBCXX_RTTI_AUTO (default) - Auto-detect from compiler flags :    
    #ifndef __GXX_RTTI
    //   __GXX_RTTI is NOT defined when -fno-rtti is active
    #define _LIBCPP_NO_RTTI
    #endif
#endif

// TizenRT compatibility: Define _LIBCPP_SAFE_STATIC for thread-safe static initialization
#define _LIBCPP_SAFE_STATIC _LIBCPP_CONSTEXPR

// TizenRT compatibility: Disable aligned allocation as TizenRT C library doesn't provide it
#define _LIBCPP_HAS_NO_C11_ALIGNED_ALLOC
#define _LIBCPP_HAS_NO_LIBRARY_ALIGNED_ALLOCATION

// TizenRT errno workaround: TizenRT implements errno as a function call macro rather than an assignable variable.
// This workaround enables libcxx to function on TizenRT by using platform-appropriate error handling.
#if defined(__TINYARA__)
#define _LIBCPP_TIZENRT_ERRNO_WORKAROUND 1
#endif

// TizenRT compatibility: Provide locale mask fallback definitions needed for locale support
// (these are not provided by TizenRT's C library)
#ifndef LC_COLLATE_MASK
#define LC_COLLATE_MASK (1<<0)
#endif
#ifndef LC_CTYPE_MASK
#define LC_CTYPE_MASK (1<<1)
#endif
#ifndef LC_MONETARY_MASK
#define LC_MONETARY_MASK (1<<2)
#endif
#ifndef LC_NUMERIC_MASK
#define LC_NUMERIC_MASK (1<<3)
#endif
#ifndef LC_TIME_MASK
#define LC_TIME_MASK (1<<4)
#endif
#ifndef LC_MESSAGES_MASK
#define LC_MESSAGES_MASK (1<<5)
#endif
#ifndef LC_ALL_MASK
#define LC_ALL_MASK (LC_COLLATE_MASK | LC_CTYPE_MASK | LC_MONETARY_MASK | LC_NUMERIC_MASK | LC_TIME_MASK | LC_MESSAGES_MASK)
#endif

// TizenRT compatibility: Disable system() function for security/size constraints
#define _LIBCPP_HAS_NO_SYSTEM

// TizenRT compatibility: TizenRT provides _exit() and _Exit() via macro
// Define this to disable _Exit function support for consistency
#define _LIBCPP_HAS_NO_C11_EXIT

#endif // _LIBCPP_CONFIG_SITE