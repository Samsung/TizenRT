{
    "version": "0.2.0",
    "configurations": [
            {
            "name": "QEMU(S1-Boot)",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/output/bin/s1_boot.elf",
            "request": "attach",
            "type": "cortex-debug",
            "servertype": "external",
            "gdbTarget": "localhost:1234",
            "gdbPath": "gdb-multiarch",
            "preAttachCommands": [
                "set substitute-path /root/tizenrt/os/include/arch/board ${workspaceFolder}/os/board/qemu-virt/include",
                "set substitute-path /root/tizenrt/os/include/arch/armv7-a ${workspaceFolder}/os/arch/arm/include/armv7-a",
                "set substitute-path /root/tizenrt/os/include/arch/chip ${workspaceFolder}/os/arch/arm/include/qemu-virt",
                "set substitute-path /root/tizenrt/os/arch/arm/src/chip ${workspaceFolder}/os/arch/arm/src/qemu-virt",
                "set substitute-path /root/tizenrt ${workspaceFolder}",
            ],
            "overrideResetCommands": [
                "monitor system_reset",
            ],
            "runToEntryPoint": "_start",
        },
        {
            "name": "QEMU(Kernel)",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/output/bin/tinyara",
            "request": "attach",
            "type": "cortex-debug",
            "servertype": "external",
            "gdbTarget": "localhost:1234",
            "gdbPath": "gdb-multiarch",
            "preAttachCommands": [
                "set substitute-path /root/tizenrt/os/include/arch/board ${workspaceFolder}/os/board/qemu-virt/include",
                "set substitute-path /root/tizenrt/os/include/arch/armv7-a ${workspaceFolder}/os/arch/arm/include/armv7-a",
                "set substitute-path /root/tizenrt/os/include/arch/chip ${workspaceFolder}/os/arch/arm/include/qemu-virt",
                "set substitute-path /root/tizenrt/os/arch/arm/src/chip ${workspaceFolder}/os/arch/arm/src/qemu-virt",
                "set substitute-path /root/tizenrt ${workspaceFolder}",
            ],
            "overrideResetCommands": [
                "monitor system_reset",
            ],
            "runToEntryPoint": "_vector_start",
        },
        {
            "name": "QEMU(XIPELF)",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/output/bin/s1_boot.elf",
            "request": "attach",
            "type": "cortex-debug",
            "servertype": "external",
            "gdbTarget": "localhost:1234",
            "gdbPath": "gdb-multiarch",
            "preAttachCommands": [
                "add-symbol-file ./build/output/bin/tinyara",
                "add-symbol-file ./build/output/bin/common_dbg",
                "add-symbol-file ./build/output/bin/app1_dbg",
                "set substitute-path /root/tizenrt/os/include/arch/board ${workspaceFolder}/os/board/qemu-virt/include",
                "set substitute-path /root/tizenrt/os/include/arch/armv7-a ${workspaceFolder}/os/arch/arm/include/armv7-a",
                "set substitute-path /root/tizenrt/os/include/arch/chip ${workspaceFolder}/os/arch/arm/include/qemu-virt",
                "set substitute-path /root/tizenrt/os/arch/arm/src/chip ${workspaceFolder}/os/arch/arm/src/qemu-virt",
                "set substitute-path /root/tizenrt ${workspaceFolder}",
            ],
            "overrideResetCommands": [
                "monitor system_reset",
            ],
            "runToEntryPoint": "_vector_start",
        },
        {
            "name": "QEMU(ELF)",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/output/bin/tinyara",
            "request": "attach",
            "type": "cortex-debug",
            "servertype": "external",
            "gdbTarget": "localhost:1234",
            "gdbPath": "gdb-multiarch",
            "preAttachCommands": [
                "set $build_output_path = \"${workspaceFolder}/build/output/bin\"",
                "source ${workspaceFolder}/build/configs/qemu-virt/tools/auto_symbol_loader.py",
                "set substitute-path /root/tizenrt/os/include/arch/board ${workspaceFolder}/os/board/qemu-virt/include",
                "set substitute-path /root/tizenrt/os/include/arch/armv7-a ${workspaceFolder}/os/arch/arm/include/armv7-a",
                "set substitute-path /root/tizenrt/os/include/arch/chip ${workspaceFolder}/os/arch/arm/include/qemu-virt",
                "set substitute-path /root/tizenrt/os/arch/arm/src/chip ${workspaceFolder}/os/arch/arm/src/qemu-virt",
                "set substitute-path /root/tizenrt ${workspaceFolder}",
            ],
            "overrideResetCommands": [
                "monitor system_reset",
            ],
            "runToEntryPoint": "_vector_start",
        }
    ]
}